    print("=== STARTING UNIT TESTS ===")
    unittest.main(argv=['first-arg-is-ignored'], exit=False)

    print("\n=== RUNNING MAIN PROGRAM ===")
    platform = RentalPlatform("City Wheels")

    v1 = VehicleFactory.create_vehicle("car", "C01", "Toyota", "Prius", 30, 4)
    v2 = VehicleFactory.create_vehicle("scooter", "S01", "Xiaomi", "Pro", 10, True)
    platform.add_vehicle(v1)
    platform.add_vehicle(v2)

    c1 = Customer("John Doe")
    platform.register_customer(c1)

    platform.show_inventory()
    platform.rent_vehicle(c1, "C01", 4)

    platform.save_inventory_to_csv("my_rental_data.csv")

    platform2 = RentalPlatform("City Wheels (Reloaded)")
    platform2.load_inventory_from_csv("my_rental_data.csv")
    platform2.show_inventory()
